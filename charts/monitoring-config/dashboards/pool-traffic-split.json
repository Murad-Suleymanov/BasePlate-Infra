      "id": 10,
      "type": "text",
      "options": {
        "mode": "markdown",
        "content": "### Pool traffic split — `$service` (namespace `$namespace`)\nRequests hitting the pool Service are load-balanced across every instance's pods. Each panel splits them by **destination_workload** (e.g. `*-main-deploy`, `*-testing-deploy`) so you can see what share of traffic each instance serves."
      }
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 4 },
      "id": 1,
      "type": "piechart",
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "tooltip": { "mode": "multi" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (destination_workload) (istio_requests_total{destination_workload_namespace=\"$namespace\", destination_service_name=\"$service\"})",
          "legendFormat": "{{destination_workload}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Total requests per instance (split, all-time)"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "drawStyle": "line", "fillOpacity": 30, "stacking": { "mode": "normal", "group": "A" } }
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 16, "x": 8, "y": 4 },
      "id": 2,
      "type": "timeseries",
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum by (destination_workload) (rate(istio_requests_total{destination_workload_namespace=\"$namespace\", destination_service_name=\"$service\"}[5m])) / ignoring(destination_workload) group_left sum (rate(istio_requests_total{destination_workload_namespace=\"$namespace\", destination_service_name=\"$service\"}[5m]))",
          "legendFormat": "{{destination_workload}}",
          "refId": "A"
        }
      ],
      "title": "Split per instance over time (%)"
    },
