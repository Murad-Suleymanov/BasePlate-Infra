      "title": "Burning SLOs",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Services burning their error budget faster than the Min burn rate. 100% is exactly on budget — it spends the whole period's budget in exactly one period. Empty is the healthy state.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "filterable": true,
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "text", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Burn rate %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 0 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "yellow", "value": null },
                    { "color": "orange", "value": 600 },
                    { "color": "red", "value": 1440 }
                  ]
                }
              },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Burn rate %" }]
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "100 * (slo:current_burn_rate:ratio{sloth_level=\"service\", sloth_slo=~\"$slo\", destination_workload_namespace=~\"$namespace\", destination_canonical_service=~\"$service\"} > $minburn)",
          "format": "table",
          "instant": true,
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Exceeded burn rate — services",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "sloth_level": true,
              "sloth_period": true
            },
            "indexByName": {},
            "renameByName": {
              "destination_canonical_service": "Service",
              "destination_workload_namespace": "Namespace",
              "sloth_slo": "SLO",
              "Value": "Burn rate %"
            }
          }
        }
      ],
      "type": "table"
    },
